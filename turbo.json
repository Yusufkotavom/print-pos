{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".next/**"],
			"env": [
				"DATABASE_URL",
				"BETTER_AUTH_SECRET",
				"BETTER_AUTH_URL",
				"BLOB_STORE_ID",
				"BLOB_READ_WRITE_TOKEN",
				"BLOB_WEBHOOK_PUBLIC_KEY",
				"POSTGRES_URL_NO_SSL",
				"PGPASSWORD",
				"NEON_AUTH_BASE_URL",
				"POSTGRES_PRISMA_URL",
				"POSTGRES_USER",
				"PGDATABASE",
				"VITE_NEON_AUTH_URL",
				"POSTGRES_URL",
				"NEON_PROJECT_ID",
				"POSTGRES_URL_NON_POOLING",
				"PGHOST",
				"DATABASE_URL_UNPOOLED",
				"PGUSER",
				"POSTGRES_PASSWORD",
				"POSTGRES_DATABASE",
				"PGHOST_UNPOOLED",
				"POSTGRES_HOST"
			]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"db:push": {
			"cache": false
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false,
			"persistent": true
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		}
	}
}
